# Copy this file to platform.env before starting the service.

# Keep this false for local LAN debugging.
# Set it to true before exposing the server to the public internet.
ASDUN_DEVICE_AUTH_ENABLED=false

# Format 1:
# ASDUN_DEVICE_TOKENS=pi-01=pi-token,asdun-cloud=cloud-token,esp32-01=esp32-token,wifi-fall-rx=fall123456
#
# Format 2:
# ASDUN_DEVICE_TOKENS={"pi-01":"pi-token","asdun-cloud":"cloud-token","esp32-01":"esp32-token","wifi-fall-rx":"fall123456"}
ASDUN_DEVICE_TOKENS=

# Optional admin token for creating device commands.
# Keep empty for local debugging. Set before exposing command APIs publicly.
ASDUN_ADMIN_TOKEN=

# On a public cloud server, the platform usually cannot reach the Raspberry Pi
# Tailscale hostname directly. Keep active probing off and rely on Pi reports.
ASDUN_PROBE_PI_ENABLED=false

# Device online timeout. If a device does not report within this window,
# the dashboard will gradually mark it stale/offline.
ASDUN_PLATFORM_ONLINE_TTL_MS=30000
